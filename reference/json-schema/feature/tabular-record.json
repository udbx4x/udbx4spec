{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/udbx4x/udbx4spec/schemas/feature/tabular-record.json",
  "title": "TabularRecord",
  "description": "UDBX Tabular Record - attribute-only record without geometry",
  "type": "object",
  "required": ["id", "attributes"],
  "properties": {
    "id": {
      "type": "integer",
      "minimum": 1,
      "description": "Record unique identifier (SmID)"
    },
    "attributes": {
      "type": "object",
      "description": "User-defined field key-value pairs",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
