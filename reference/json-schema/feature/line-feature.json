{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/udbx4x/udbx4spec/schemas/feature/line-feature.json",
  "title": "LineFeature",
  "description": "UDBX Line Feature - specialized Feature with MultiLineStringGeometry",
  "type": "object",
  "required": ["id", "geometry", "attributes"],
  "properties": {
    "id": {
      "type": "integer",
      "minimum": 1,
      "description": "Feature unique identifier (SmID)"
    },
    "geometry": {
      "$ref": "../geometry/multi-line-string.json",
      "description": "MultiLineString geometry"
    },
    "attributes": {
      "type": "object",
      "description": "User-defined field key-value pairs",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
